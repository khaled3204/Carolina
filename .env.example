# Required in production — random secret for admin sessions
SESSION_SECRET=change-me-to-a-long-random-string

# Public site URL (used in password-reset emails)
SITE_URL=https://your-carolina-site.vercel.app

# Gmail for password reset (use an App Password, not your normal password)
# Account: shop.carolina.eg@gmail.com
GMAIL_USER=shop.carolina.eg@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Optional: Vercel Blob token for durable product/sales storage on Vercel
# Create a Blob store in the Vercel dashboard, then paste the token.
BLOB_READ_WRITE_TOKEN=
